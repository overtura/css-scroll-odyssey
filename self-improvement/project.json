{
  "name": "CSS Scroll Odyssey",
  "kind": "html-css-only-scroll-story",
  "runtime": "Static HTML + CSS + Vite build only",
  "language": "ko",
  "goal": "스크롤 기반 CSS 모션 스토리를 밝은 no-JS 페이지로 축적하고, 자동 PR로 장면, 접근성, fallback을 개선한다.",
  "allowedChangeScope": [
    "index.html",
    "styles.css",
    "design-system/**",
    "DESIGN.md",
    "README.md",
    "docs/**",
    ".github/workflows/**",
    ".github/prompts/**",
    "self-improvement/**",
    "scripts/**",
    "package.json"
  ],
  "blockedChangeScope": [
    "src/**",
    ".env*",
    "*.pem",
    "*.key",
    ".npmrc",
    "런타임 JavaScript",
    "실제 API key 또는 credential"
  ],
  "qualityGates": [
    "pnpm self-improve:guard",
    "pnpm check"
  ]
}
